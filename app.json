{
  "expo": {
    "name": "Sunnyvale Connect",
    "slug": "sunnyvale-connect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0C3023"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sunnyvale.connect"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.sunnyvale.connect"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "react-native-reanimated"
    ],
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:8000"
    }
  }
}
